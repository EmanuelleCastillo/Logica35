programa {
  funcao inicio() {
   real gasolina, preco, pagar

   escreva("Quantos reais você deseja colocar de gasolina?")
   leia(pagar)

   escreva("Qual o valor de cada litro de gasolina?")
   leia(preco)

   gasolina= pagar/preco

   escreva("Você consegue colocar ", gasolina,"L com esse valor.")
  }
}
