programa {
  funcao inicio() {
  inteiro dia_semana

  escreva("Digite o nº do dia da semana")
  leia(dia_semana)

  escolha(dia_semana){
  caso 1: escreva("Domingo")
  pare
  caso 2: escreva("Sábado")
  pare
  caso 3: escreva("Sexta")
  pare
  caso 4: escreva("Quinta")
  pare
  caso 5: escreva("Quarta")
  pare
  caso 6: escreva("Terça")
  pare
  caso 7: escreva("Segunda")
  pare
  caso contrario: escreva("Tente novamente")
  pare
  }

  }
}
