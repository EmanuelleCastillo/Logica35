programa {
  funcao inicio() { 
  cadeia nome
  inteiro idade
  real salario
  logico ativo = verdadeiro 
  caracter estado_civil, estadoCivil = 'S'
  const cadeia lotacao = "Brasília"

  escreva("Digite seu nome:")
  leia(nome)

  escreva("Seu nome é:",nome)

  escreva("\nDigite sua idade,",nome,":")
  leia(idade)
  escreva("Sua idade é:", idade )
  }
}
